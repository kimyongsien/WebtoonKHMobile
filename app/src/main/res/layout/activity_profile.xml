<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="16sp"
            android:textColor="#555555"
            android:paddingBottom="12dp" />

        <!-- Profile Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:background="@drawable/bg_profile_card">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/website_logo"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sok Chomroeun"
                    android:textSize="20sp"
                    android:textColor="#111111" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="sokchomroeun770@gmail.com"
                    android:textSize="12sp"
                    android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bookmark Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_profile_card">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Bookmarks"
                android:textSize="17sp"
                android:textColor="#111111" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgBookmarkCover"
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/txtBookmarkTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="No bookmark yet"
                    android:textSize="14sp"
                    android:textColor="#111111" />

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="→"
                    android:textSize="34sp"
                    android:textColor="#111111" />
            </LinearLayout>
        </LinearLayout>

        <!-- Read Later Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_profile_card">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read Later"
                android:textSize="17sp"
                android:textColor="#111111" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgReadLaterCover"
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/txtReadLaterTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="No read later yet"
                    android:textSize="14sp"
                    android:textColor="#111111" />

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="→"
                    android:textSize="34sp"
                    android:textColor="#111111" />
            </LinearLayout>
        </LinearLayout>

        <!-- View History Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="135dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_profile_card">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View History"
                android:textSize="17sp"
                android:textColor="#111111" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgHistoryCover"
                    android:layout_width="70dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/txtHistoryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="No history yet"
                    android:textSize="13sp"
                    android:textColor="#111111" />

                <TextView
                    android:layout_width="95dp"
                    android:layout_height="wrap_content"
                    android:text="display only\nthe last view\nstory"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>