<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="16sp"
            android:textColor="#555555"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="10dp" />

        <!-- Profile Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:orientation="vertical"
            android:padding="22dp"
            android:background="@drawable/bg_profile_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    android:src="@drawable/website_logo"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sok Chomroeun"
                        android:textSize="20sp"
                        android:textColor="#111111" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="sokchomroeun770@gmail.com"
                        android:textSize="12sp"
                        android:textColor="#777777" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- My Bookmarks -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_margin="18dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/bg_profile_card">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Bookmarks"
                android:textSize="17sp"
                android:textColor="#111111" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/bookmarkContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/imgBookmarkCover"
                            android:layout_width="92dp"
                            android:layout_height="92dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_circle" />

                        <TextView
                            android:id="@+id/txtBookmarkTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No bookmark yet"
                            android:textSize="12sp"
                            android:textColor="#111111"
                            android:gravity="center"
                            android:maxLines="2"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Read Later -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="18dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/bg_profile_card">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read Later"
                android:textSize="17sp"
                android:textColor="#111111" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/readLaterContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/imgReadLaterCover"
                            android:layout_width="96dp"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop" />

                        <TextView
                            android:id="@+id/txtReadLaterTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No read later yet"
                            android:textSize="12sp"
                            android:textColor="#111111"
                            android:gravity="center"
                            android:maxLines="2"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- View History -->
        <LinearLayout
            android:id="@+id/cardViewHistory"
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/bg_profile_card">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View History"
                android:textSize="17sp"
                android:textColor="#111111" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgHistoryCover"
                    android:layout_width="72dp"
                    android:layout_height="82dp"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtHistoryTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No history yet"
                        android:textSize="14sp"
                        android:textColor="#111111"
                        android:maxLines="1" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="view recently"
                        android:textSize="12sp"
                        android:textColor="#777777"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>