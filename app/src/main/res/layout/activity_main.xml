<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="64dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Featured Banner -->
            <FrameLayout
                android:id="@+id/featuredBanner"
                android:layout_width="match_parent"
                android:layout_height="330dp">

                <ImageView
                    android:id="@+id/imgFeatured"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_featured_overlay" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_green_pill"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="FEATURED WEBTOON"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtFeaturedTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="Featured Title"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:maxLines="2" />

                    <TextView
                        android:id="@+id/txtFeaturedAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Author"
                        android:textColor="#DDFFFFFF"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnReadNow"
                            android:layout_width="135dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:background="@drawable/bg_green_pill"
                            android:text="Read Now"
                            android:textColor="#07120B"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnMyList"
                            android:layout_width="120dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="14dp"
                            android:gravity="center"
                            android:background="@drawable/bg_outline_pill"
                            android:text="+  My List"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="8dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="48dp"
                        android:background="@drawable/bg_green_pill" />

                </LinearLayout>
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trending &amp; Popular Series"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="18dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerWebtoon"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_webtoon" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top Picks For You"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTopPicks"
                android:layout_width="match_parent"
                android:layout_height="430dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_webtoon" />

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/view_home_header" />

    <include layout="@layout/view_floating_bottom_nav" />

</FrameLayout>
